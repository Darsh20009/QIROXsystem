{
  "name": "QIROX Studio | مصنع الأنظمة الرقمية",
  "short_name": "QIROX",
  "description": "منصة بناء الأنظمة الرقمية المتكاملة — نبني أنظمة، نبقى بشراً",
  "start_url": "/?source=pwa",
  "scope": "/",
  "id": "qirox-studio-pwa-v1",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "tabbed", "standalone", "minimal-ui", "browser"],
  "orientation": "any",
  "background_color": "#111111",
  "theme_color": "#111111",
  "lang": "ar",
  "dir": "rtl",
  "categories": ["business", "productivity", "utilities"],

  "icons": [
    { "src": "/favicon-16.png",           "sizes": "16x16",   "type": "image/png", "purpose": "any" },
    { "src": "/favicon-32.png",           "sizes": "32x32",   "type": "image/png", "purpose": "any" },
    { "src": "/favicon-48.png",           "sizes": "48x48",   "type": "image/png", "purpose": "any" },
    { "src": "/icon-70.png",              "sizes": "70x70",   "type": "image/png", "purpose": "any" },
    { "src": "/apple-touch-icon-120.png", "sizes": "120x120", "type": "image/png", "purpose": "any" },
    { "src": "/icon-144.png",             "sizes": "144x144", "type": "image/png", "purpose": "any" },
    { "src": "/apple-touch-icon-152.png", "sizes": "152x152", "type": "image/png", "purpose": "any" },
    { "src": "/apple-touch-icon-180.png", "sizes": "180x180", "type": "image/png", "purpose": "any" },
    { "src": "/icon-150.png",             "sizes": "150x150", "type": "image/png", "purpose": "any" },
    { "src": "/icon-192.png",             "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/icon-192-maskable.png",    "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "/icon-256.png",             "sizes": "256x256", "type": "image/png", "purpose": "any" },
    { "src": "/icon-310.png",             "sizes": "310x310", "type": "image/png", "purpose": "any" },
    { "src": "/icon-512.png",             "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/icon-512-maskable.png",    "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],

  "screenshots": [
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "لوحة تحكم QIROX Studio على الجوال"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "wide",
      "label": "لوحة تحكم QIROX Studio على سطح المكتب"
    }
  ],

  "shortcuts": [
    {
      "name": "لوحة التحكم",
      "short_name": "Dashboard",
      "description": "الذهاب للوحة التحكم الرئيسية",
      "url": "/dashboard?source=shortcut",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "طلب جديد",
      "short_name": "طلب",
      "description": "تقديم طلب خدمة جديد",
      "url": "/order?source=shortcut",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "عرض الأسعار",
      "short_name": "الأسعار",
      "description": "استعراض باقات الأسعار",
      "url": "/prices?source=shortcut",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "تواصل معنا",
      "short_name": "تواصل",
      "description": "التواصل مع فريق QIROX",
      "url": "/contact?source=shortcut",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],

  "related_applications": [
    {
      "platform": "play",
      "url": "https://apkpure.com/p/online.qiroxstudio.twa",
      "id": "online.qiroxstudio.twa"
    },
    {
      "platform": "windows",
      "url": "https://apps.microsoft.com/store/detail/qirox-studio"
    },
    {
      "platform": "webapp",
      "url": "https://qiroxstudio.online/manifest.json"
    }
  ],
  "prefer_related_applications": false,

  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",

  "scope_extensions": [
    { "origin": "https://dashboard.qiroxstudio.online" },
    { "origin": "https://app.qiroxstudio.online" }
  ],

  "protocol_handlers": [
    {
      "protocol": "web+qirox",
      "url": "/handle?protocol=%s"
    },
    {
      "protocol": "mailto",
      "url": "/contact?email=%s"
    }
  ],

  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["image/*", "application/pdf", ".doc", ".docx", ".xls", ".xlsx"]
        }
      ]
    }
  },

  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "application/pdf": [".pdf"],
        "image/png": [".png"],
        "image/jpeg": [".jpg", ".jpeg"],
        "image/webp": [".webp"],
        "application/vnd.ms-excel": [".xls"],
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": [".xlsx"]
      },
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }],
      "launch_type": "single-client"
    }
  ],

  "widgets": [
    {
      "name": "QIROX Dashboard",
      "short_name": "QIROX",
      "description": "عرض إحصائيات لوحة تحكم QIROX",
      "tag": "qirox-dashboard-widget",
      "template": "qirox-widget-template",
      "ms_ac_template": "/widget-template.json",
      "data": "/api/widget/stats",
      "type": "application/json",
      "screenshots": [
        {
          "src": "/icon-310x150.png",
          "sizes": "310x150",
          "label": "QIROX Widget Preview"
        }
      ],
      "icons": [
        { "src": "/icon-144.png", "sizes": "144x144" }
      ],
      "auth": true,
      "update": 3600
    }
  ],

  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "note_taking": {
    "new_note_url": "/order?type=note&source=pwa"
  },
  "tabbed_display_mode": {
    "tabs": [
      {
        "name": "لوحة التحكم",
        "url": "/dashboard"
      },
      {
        "name": "الطلبات",
        "url": "/order"
      },
      {
        "name": "الأسعار",
        "url": "/prices"
      }
    ]
  }
}
